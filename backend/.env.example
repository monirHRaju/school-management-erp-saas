# Server
NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string (get from Atlas: Cluster → Connect → Connect your application)
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/DATABASE

# JWT: a long random string YOU create. Used to sign/verify auth tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Never commit the real value; keep it only in .env (which is gitignored).
JWT_SECRET=your-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS later); set to your Next.js dev URL or production URL
FRONTEND_URL=http://localhost:3000
